# API
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=15000

# App
VITE_APP_NAME=Voltura
VITE_APP_ENV=development

# Mock mode — when true, API calls are served from in-memory seed data
# (src/mocks/) instead of hitting the real backend. Useful for frontend-only
# development before the backend is running, or for demos.
VITE_USE_MOCK_API=true

# Auth storage keys (rarely need to change; surfaced here for transparency)
VITE_ACCESS_TOKEN_KEY=voltura_access_token
VITE_REFRESH_TOKEN_KEY=voltura_refresh_token
