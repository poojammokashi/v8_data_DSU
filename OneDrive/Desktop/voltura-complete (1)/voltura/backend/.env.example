# ===========================
# App
# ===========================
APP_NAME=Voltura Electricity Management API
APP_ENV=development
API_V1_PREFIX=/api/v1
DEBUG=true

# ===========================
# Database
# ===========================
DATABASE_URL=postgresql+psycopg2://voltura_user:voltura_pass@localhost:5432/voltura_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ===========================
# JWT Auth
# ===========================
JWT_SECRET_KEY=replace-this-with-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30

# ===========================
# CORS
# ===========================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ===========================
# File uploads
# ===========================
MAX_UPLOAD_SIZE_MB=10
UPLOAD_TEMP_DIR=/tmp/voltura_uploads

# ===========================
# Rate limiting
# ===========================
RATE_LIMIT_LOGIN=5/minute

# ===========================
# Logging
# ===========================
LOG_LEVEL=INFO
LOG_JSON=true

# ===========================
# Super admin seed (first boot only)
# ===========================
SUPERADMIN_EMAIL=superadmin@voltura.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=Super Admin
